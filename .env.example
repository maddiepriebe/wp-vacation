# =========================================================================
# wp-vacation — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# =========================================================================

# -------- Database (Supabase Postgres) ------------------------------------
# Pooled connection (port 6543) used by the running app at runtime.
# Available in Supabase dashboard → Project Settings → Database → "Connection pooling"
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) used by drizzle-kit for migrations only.
# Available in Supabase dashboard → Project Settings → Database → "Connection string"
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# -------- Auth (Clerk) ----------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Signing secret for the Clerk webhook (Clerk dashboard → Webhooks)
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk paths (defaults are fine; uncomment to override)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# -------- Email (Resend) — Phase 5, leave blank for Phase 1 ---------------
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=no-reply@example.com

# -------- Observability (Sentry) — optional in Phase 1 --------------------
# If SENTRY_DSN is blank, Sentry is a no-op and next.config.ts skips the wrapper.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# -------- App ------------------------------------------------------------
# Public URL of the deployment (used for webhook + Clerk redirect bases)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node env is set by Next.js; do not set manually

# -------- E2E (Playwright) — dev only -------------------------------------
# Used by tests/e2e/global.setup.ts to find-or-create a Clerk test user
# and a matching admin row. Defaults are wired in the setup file; override
# here if you want different credentials. Requires a Clerk dev instance
# (pk_test_* / sk_test_*) — the setup refuses live keys.
# E2E_ADMIN_EMAIL=admin+clerk_test@example.com
# E2E_ADMIN_PASSWORD=set-a-strong-password-here
